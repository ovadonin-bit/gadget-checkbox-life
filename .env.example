# Supabase (shared project with checkbox.life — but uses g_* tables)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (для загрузки фото через scripts/upload_images.py)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gadget-images
R2_PUBLIC_URL=https://img.gadget.checkbox.life

# DeepSeek (для генерации описаний)
DEEPSEEK_API_KEY=

# Admitad (deeplink-генератор biggeek.ru) — заполнить когда придёт оффер
ADMITAD_CAMPAIGN_ID=
ADMITAD_AFFILIATE_ID=
ADMITAD_SUBID=gadget
